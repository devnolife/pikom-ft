generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MAHASISWA
  PENGURUS
  ADMIN
}

enum Jabatan {
  KETUA_UMUM
  SEKRETARIS_UMUM
  BENDAHARA_UMUM
  KETUA_BIDANG
  ANGGOTA_BIDANG
}

enum TipeSurat {
  MASUK
  KELUAR
}

enum KategoriAturan {
  TOR
  AD_ART
  SOP
  LAIN
}

enum TipeTransaksi {
  PEMASUKAN
  PENGELUARAN
}

model User {
  id        String   @id @default(cuid())
  nim       String   @unique
  name      String
  password  String
  role      Role     @default(MAHASISWA)
  jabatan   Jabatan?
  bidang    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  progress    Progress[]
  prokerMade  Proker[]    @relation("ProkerCreator")
  suratMade   Surat[]     @relation("SuratCreator")
  aturanMade  Aturan[]    @relation("AturanCreator")
  transaksiMade Transaksi[] @relation("TransaksiCreator")
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  title     String
  status    String   @default("belum")
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProfilOrganisasi {
  id          String @id @default(cuid())
  key         String @unique
  value       String
  updatedAt   DateTime @updatedAt
}

model Proker {
  id          String   @id @default(cuid())
  bidang      String
  title       String
  status      String   @default("direncanakan")
  deskripsi   String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator User? @relation("ProkerCreator", fields: [createdById], references: [id], onDelete: SetNull)
}

model Surat {
  id          String    @id @default(cuid())
  tipe        TipeSurat
  nomor       String
  tanggal     DateTime
  perihal     String
  pengirim    String?
  tujuan      String?
  lampiranUrl String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  creator User? @relation("SuratCreator", fields: [createdById], references: [id], onDelete: SetNull)
}

model Aturan {
  id          String         @id @default(cuid())
  judul       String
  kategori    KategoriAturan
  konten      String?
  lampiranUrl String?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  creator User? @relation("AturanCreator", fields: [createdById], references: [id], onDelete: SetNull)
}

model Transaksi {
  id          String        @id @default(cuid())
  tipe        TipeTransaksi
  tanggal     DateTime
  kategori    String
  jumlah      Int
  deskripsi   String?
  pihak       String?
  bidang      String?
  notaUrl     String?
  createdById String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  creator User? @relation("TransaksiCreator", fields: [createdById], references: [id], onDelete: SetNull)
}
